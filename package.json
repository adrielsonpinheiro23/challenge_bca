{
  "name": "bca-playwright-assessment",
  "version": "1.0.0",
  "description": "API and UI test automation suite for the BCA take-home challenge.",
  "scripts": {
    "test": "playwright test",
    "test:api": "playwright test src/api/tests",
    "test:ui": "playwright test src/ui/tests",
    "test:visual": "playwright test -c playwright.visual.config.ts",
    "test:visual:update": "playwright test -c playwright.visual.config.ts --update-snapshots",
    "test:headed": "playwright test src/ui/tests --headed",
    "test:report": "playwright test --reporter=html,json",
    "report": "playwright show-report",
    "report:allure:generate": "allure generate allure-results --clean -o reports/allure-report",
    "report:allure": "allure open reports/allure-report",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier . --write",
    "format:check": "prettier . --check"
  },
  "keywords": [
    "playwright",
    "typescript",
    "api-testing",
    "ui-testing"
  ],
  "author": "Adrielson Pinheiro",
  "license": "MIT",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.60.0",
    "@types/node": "^25.9.3",
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1",
    "allure-commandline": "^2.43.0",
    "allure-playwright": "^3.10.1",
    "dotenv": "^17.2.3",
    "eslint": "^10.5.0",
    "prettier": "^3.8.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.0"
  }
}
